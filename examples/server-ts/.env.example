# App environment: production | development | test
APP_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=simple_auth_example:

# OTP bypass code (dev/test only — ignored in production)
AUTH_BYPASS_CODE=123456

# JWT secret (required — generate with: openssl rand -base64 32)
# JWT_SECRET=your-32-char-minimum-secret

# Optional: log OTP codes in non-production for local debugging (never enable in shared environments)
# SIMPLE_AUTH_LOG_OTP=true

# Optional: restrict all enabled sign-in methods to these email domains (comma-separated)
# ALLOWED_EMAIL_DOMAINS=crown.dev,example.com

# Google OAuth (optional — omit to disable)
# GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-placeholder

# Server port
PORT=3005
